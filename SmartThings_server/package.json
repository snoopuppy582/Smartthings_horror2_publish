{
  "name": "smartthings-horror-server",
  "version": "1.0.0",
  "description": "SmartThings IoT 공포 게임 중계 서버",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test src/*.test.js scripts/*.test.js",
    "verify:iot": "node src/realIotSmoke.js",
    "verify:submission": "node scripts/submissionStatus.js",
    "verify:submission:final": "node scripts/submissionStatus.js --require-real-iot",
    "manual:init": "node scripts/manualPlaytestEvidence.js --init",
    "manual:record": "node scripts/manualPlaytestEvidence.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
